# ============================
# Node.js & pnpm 专属配置
# ============================

# 依赖目录 (绝对不要提交)
node_modules/
.pnpm-store/

# 锁定文件 (pnpm-lock.yaml 通常建议提交，但如果你只想提交代码逻辑可忽略)
# ⚠️ 建议：保留 pnpm-lock.yaml 的提交，以保证团队依赖版本一致。
# 如果你想忽略它，取消下面这行的注释：
# pnpm-lock.yaml

# 环境变量 (包含密钥，绝对不要提交)
.env
.env.local
.env.*.local

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 操作系统生成的文件
.DS_Store
Thumbs.db
desktop.ini

# IDE 配置 (可选，根据团队习惯决定)
.vscode/
.idea/
*.swp
*.swo

# 构建输出目录 (如果有打包操作)
dist/
build/

# 临时文件
tmp/
temp/